{
  "name": "ubcab-bo-mcp",
  "version": "1.0.0",
  "description": "MCP server for the UBCab Backoffice (registration-bo) API. Keycloak SSO auth, driver search / detail / rating / state.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/api/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test:login": "node scripts/test-login.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vercel/node": "^3.2.0",
    "typescript": "^5.5.0"
  }
}

# ===========================================================================
# UBCab Backoffice (registration-bo) — Keycloak SSO auth
# ===========================================================================
# Option A (recommended): password grant. The server logs in with these and
# auto-refreshes tokens itself. Use a dedicated BO account if possible.
UBCAB_BO_USERNAME=naranmunkh@ubcab.mn
UBCAB_BO_PASSWORD=replace-me

# Option B: refresh-token grant (if the account uses 2FA / SSO and direct
# password grant is disabled). Paste a fresh refresh_token. Note these expire,
# so password grant is more durable for an always-on server.
UBCAB_BO_REFRESH_TOKEN=

# OIDC client used by the operator BO web app. Usually leave as default.
UBCAB_BO_CLIENT_ID=ubcab-registration-bo

# ===========================================================================
# Base URLs (defaults match production; override only if they change)
# ===========================================================================
UBCAB_BO_SSO_URL=https://sso.ubcabtech.com
UBCAB_BO_REALM=ubcab-bo
UBCAB_BO_API_URL=https://registration-bo-api.ubcabtech.com
# Sent as Origin/Referer to satisfy the BO allowed-origins check.
UBCAB_BO_ORIGIN=https://operator.ubcab.mn

# ===========================================================================
# Remote (Vercel) deployment only
# Secret bearer token clients must send to reach the /mcp endpoint.
# Generate one with:  openssl rand -hex 32
# REQUIRED in production — the endpoint fails closed without it.
# ===========================================================================
UBCAB_BO_MCP_AUTH_TOKEN=
